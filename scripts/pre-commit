#!/usr/bin/env bash
# Pre-commit hook for bwa-rust
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

set -e

echo "🔍 Running pre-commit checks..."

# Check for staged Rust files
STAGED_RS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
STAGED_TOML_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.toml$' || true)

if [ -z "$STAGED_RS_FILES" ] && [ -z "$STAGED_TOML_FILES" ]; then
    echo "✅ No Rust or TOML files to check"
    exit 0
fi

# 1. Format check
echo "📝 Checking formatting..."
if ! cargo fmt --all -- --check; then
    echo "❌ Format check failed. Run: cargo fmt --all"
    exit 1
fi

# 2. Clippy check on staged files
echo "🔧 Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings; then
    echo "❌ Clippy failed. Fix warnings or run: cargo clippy --fix --allow-dirty"
    exit 1
fi

# 3. Basic compilation check
echo "🔨 Checking compilation..."
if ! cargo check --all-targets --all-features; then
    echo "❌ Compilation failed."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
exit 0
